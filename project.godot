; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="shoot"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

AssetDB="*res://scripts/asset_db.gd"
GameManager="*res://scripts/game_manager.gd"
UpgradeManager="*res://scripts/upgrades/upgrade_manager.gd"
ProgressManager="*res://scripts/progress_manager.gd"
SaveManager="*res://scripts/save_manager.gd"

[dotnet]

project/assembly_name="shoot"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
rendering/viewport/transparent_background=false
rendering/environment/defaults/default_clear_color=Color(0.05, 0.05, 0.12, 1)
