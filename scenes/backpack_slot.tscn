[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/backpack_slot.gd" id="1_slot"]

[node name="BackpackSlot" type="Panel"]
custom_minimum_size = Vector2(64, 64)
script = ExtResource("1_slot")

[node name="VBox" type="VBoxContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 3.0
offset_top = 3.0
offset_right = -3.0
offset_bottom = -3.0
theme_override_constants/separation = 2

[node name="LockLabel" type="Label" parent="VBox"]
size_flags_vertical = 3
text = "🔒"
horizontal_alignment = 1
vertical_alignment = 1
theme_override_font_sizes/font_size = 24

[node name="NameLabel" type="Label" parent="VBox"]
size_flags_vertical = 3
text = "名称"
horizontal_alignment = 1
vertical_alignment = 1
theme_override_font_sizes/font_size = 10
autowrap_mode = 2

[node name="CountLabel" type="Label" parent="VBox"]
text = "×1"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 10

[node name="HBox" type="HBoxContainer" parent="VBox"]
theme_override_constants/separation = 2

[node name="ActionButton" type="Button" parent="VBox/HBox"]
text = "装 备"
theme_override_font_sizes/font_size = 8
custom_minimum_size = Vector2(0, 18)
size_flags_horizontal = 3

[node name="DiscardButton" type="Button" parent="VBox/HBox"]
text = "丢 弃"
theme_override_font_sizes/font_size = 8
custom_minimum_size = Vector2(0, 18)
size_flags_horizontal = 2

[connection signal="pressed" from="VBox/HBox/ActionButton" to="." method="_on_action_button_pressed"]
[connection signal="pressed" from="VBox/HBox/DiscardButton" to="." method="_on_discard_button_pressed"]
