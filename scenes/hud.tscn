[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/hud.gd" id="1_hud"]

[node name="HUD" type="CanvasLayer"]
layer = 10
script = ExtResource("1_hud")

[node name="Margin" type="MarginContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="HBox" type="HBoxContainer" parent="Margin"]
layout_mode = 2

[node name="LeftPanel" type="VBoxContainer" parent="Margin/HBox"]
layout_mode = 2
size_flags_horizontal = 3

[node name="HPBar" type="ProgressBar" parent="Margin/HBox/LeftPanel"]
custom_minimum_size = Vector2(200, 18)
value = 100.0
show_percentage = false

[node name="XPBar" type="ProgressBar" parent="Margin/HBox/LeftPanel"]
custom_minimum_size = Vector2(200, 12)
value = 0.0
show_percentage = false

[node name="LevelLabel" type="Label" parent="Margin/HBox/LeftPanel"]
text = "Lv.1"

[node name="Spacer" type="Control" parent="Margin/HBox"]
layout_mode = 2
size_flags_horizontal = 3

[node name="RightPanel" type="VBoxContainer" parent="Margin/HBox"]
layout_mode = 2

[node name="TimerLabel" type="Label" parent="Margin/HBox/RightPanel"]
text = "00:00"
horizontal_alignment = 2

[node name="EnemiesLabel" type="Label" parent="Margin/HBox/RightPanel"]
text = "Kills: 0"
horizontal_alignment = 2

[node name="GameOverPanel" type="Panel" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -160.0
offset_top = -120.0
offset_right = 160.0
offset_bottom = 120.0

[node name="VBox" type="VBoxContainer" parent="GameOverPanel"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="GameOverLabel" type="Label" parent="GameOverPanel/VBox"]
text = "GAME OVER"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 24

[node name="TimeLabel" type="Label" parent="GameOverPanel/VBox"]
text = "Survived: 00:00"
horizontal_alignment = 1

[node name="ScoreLabel" type="Label" parent="GameOverPanel/VBox"]
text = "Score: 0"
horizontal_alignment = 1

[node name="RestartButton" type="Button" parent="GameOverPanel/VBox"]
text = "Play Again"

[connection signal="pressed" from="GameOverPanel/VBox/RestartButton" to="." method="_on_restart_pressed"]
