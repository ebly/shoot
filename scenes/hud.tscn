[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/hud.gd" id="1_hud"]

[node name="HUD" type="CanvasLayer"]
layer = 10
script = ExtResource("1_hud")

[node name="Margin" type="MarginContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="HBox" type="HBoxContainer" parent="Margin"]
layout_mode = 2

[node name="LeftPanel" type="VBoxContainer" parent="Margin/HBox"]
layout_mode = 2
size_flags_horizontal = 3

[node name="HPBar" type="ProgressBar" parent="Margin/HBox/LeftPanel"]
custom_minimum_size = Vector2(200, 18)
value = 100.0
show_percentage = false

[node name="XPBar" type="ProgressBar" parent="Margin/HBox/LeftPanel"]
custom_minimum_size = Vector2(200, 12)
value = 0.0
show_percentage = false

[node name="LevelLabel" type="Label" parent="Margin/HBox/LeftPanel"]
text = "等级 1"

[node name="Spacer" type="Control" parent="Margin/HBox"]
layout_mode = 2
size_flags_horizontal = 3

[node name="RightPanel" type="VBoxContainer" parent="Margin/HBox"]
layout_mode = 2

[node name="GoldLabel" type="Label" parent="Margin/HBox/RightPanel"]
text = "金币: 0"
horizontal_alignment = 2
theme_override_colors/font_color = Color(0.95, 0.80, 0.20, 1)

[node name="TimerLabel" type="Label" parent="Margin/HBox/RightPanel"]
text = "00:00"
horizontal_alignment = 2

[node name="EnemiesLabel" type="Label" parent="Margin/HBox/RightPanel"]
text = "击杀: 0"
horizontal_alignment = 2

[node name="BackpackButton" type="Button" parent="Margin/HBox/RightPanel"]
text = "背 包"
theme_override_font_sizes/font_size = 12

[node name="GameOverPanel" type="Panel" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -160.0
offset_top = -120.0
offset_right = 160.0
offset_bottom = 120.0

[node name="VBox" type="VBoxContainer" parent="GameOverPanel"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="GameOverLabel" type="Label" parent="GameOverPanel/VBox"]
text = "游 戏 结 束"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 24

[node name="TimeLabel" type="Label" parent="GameOverPanel/VBox"]
text = "存活: 00:00"
horizontal_alignment = 1

[node name="ScoreLabel" type="Label" parent="GameOverPanel/VBox"]
text = "得分: 0"
horizontal_alignment = 1

[node name="RestartButton" type="Button" parent="GameOverPanel/VBox"]
text = "再来一局"

[node name="MapButton" type="Button" parent="GameOverPanel/VBox"]
text = "返回地图"
theme_override_font_sizes/font_size = 12

[node name="StageClearPanel" type="Panel" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -160.0
offset_top = -120.0
offset_right = 160.0
offset_bottom = 120.0

[node name="VBox" type="VBoxContainer" parent="StageClearPanel"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="ClearLabel" type="Label" parent="StageClearPanel/VBox"]
text = "关 卡 通 过 !"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 24
theme_override_colors/font_color = Color(0.2, 0.85, 0.2, 1)

[node name="ClearScoreLabel" type="Label" parent="StageClearPanel/VBox"]
text = "得分: 0"
horizontal_alignment = 1

[node name="ContinueButton" type="Button" parent="StageClearPanel/VBox"]
text = "继 续"
theme_override_font_sizes/font_size = 18

[connection signal="pressed" from="Margin/HBox/RightPanel/BackpackButton" to="." method="_on_backpack_pressed"]
[connection signal="pressed" from="GameOverPanel/VBox/RestartButton" to="." method="_on_restart_pressed"]
[connection signal="pressed" from="GameOverPanel/VBox/MapButton" to="." method="_on_gameover_map_pressed"]
[connection signal="pressed" from="StageClearPanel/VBox/ContinueButton" to="." method="_on_stage_continue_pressed"]
