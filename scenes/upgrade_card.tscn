[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/upgrade_card.gd" id="1_card"]

[node name="UpgradeCard" type="Panel"]
custom_minimum_size = Vector2(180, 220)
script = ExtResource("1_card")

[node name="VBox" type="VBoxContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="NameLabel" type="Label" parent="VBox"]
text = "升级名称"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 14

[node name="DescLabel" type="Label" parent="VBox"]
text = "描述"
horizontal_alignment = 1
autowrap_mode = 2
size_flags_vertical = 3

[node name="Buttons" type="HBoxContainer" parent="VBox"]
size_flags_vertical = 0
theme_override_constants/separation = 6

[node name="PickButton" type="Button" parent="VBox/Buttons"]
text = "拾 取"
size_flags_horizontal = 3

[node name="EquipButton" type="Button" parent="VBox/Buttons"]
text = "装 备"
size_flags_horizontal = 3

[connection signal="pressed" from="VBox/Buttons/PickButton" to="." method="_on_pick_button_pressed"]
[connection signal="pressed" from="VBox/Buttons/EquipButton" to="." method="_on_equip_button_pressed"]
